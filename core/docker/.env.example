# LLM Provider (at least one required for opencode)
ANTHROPIC_API_KEY=

# Epsilon (provider + master proxy)
EPSILON_API_URL=http://localhost:8008
EPSILON_TOKEN=

# Sandbox metadata
SANDBOX_ID=local
PROJECT_ID=local
ENV_MODE=local

# Tool API keys
TAVILY_API_KEY=
FIRECRAWL_API_KEY=
SERPER_API_KEY=
REPLICATE_API_TOKEN=
CONTEXT7_API_KEY=
ELEVENLABS_API_KEY=

# Tool API URL overrides (optional — leave empty to use real upstream APIs directly)
# In cloud mode these are set automatically to route through the Epsilon router proxy.
# TAVILY_API_URL=
# SERPER_API_URL=
# REPLICATE_API_URL=

# OpenAI (used by lss for semantic search embeddings)
OPENAI_API_KEY=

# Semantic Search (lss) — optional overrides
# LSS_DIR=/workspace/.lss   # Database directory (default: ~/.lss)

# ── Residential Proxy (optional) ────────────────────────────────────────────
# Routes browser traffic through a residential proxy to avoid bot detection.
# Used by agent-browser (Playwright/Chromium). Get credentials from a provider:
#   IPRoyal:    http://user:pass@geo.iproyal.com:12321       (~$1.75/GB)
#   Bright Data: http://user:pass@brd.superproxy.io:22225     (~$4/GB)
#   Smartproxy: http://user:pass@gate.smartproxy.com:7777     (~$2.25/GB)
#   Oxylabs:    http://user:pass@pr.oxylabs.io:7777           (~$4/GB)
# AGENT_BROWSER_PROXY=http://user:pass@proxy.example.com:8080

# Epsilon Agent Personal Email Inbox (SMTP/IMAP)
# This is the agent's OWN email identity, not the user's.
EPSILON_AGENT_EMAIL_INBOX_FROM_NAME=
EPSILON_AGENT_EMAIL_INBOX_FROM_EMAIL=
EPSILON_AGENT_EMAIL_INBOX_USER_NAME=
EPSILON_AGENT_EMAIL_INBOX_PASSWORD=
EPSILON_AGENT_EMAIL_INBOX_SMTP_HOST=
EPSILON_AGENT_EMAIL_INBOX_SMTP_PORT=465
EPSILON_AGENT_EMAIL_INBOX_IMAP_HOST=
EPSILON_AGENT_EMAIL_INBOX_IMAP_PORT=993
