{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "allow",
    "task": "deny"
  },
  "autoupdate": false,
  "disabled_providers": [],
  "default_agent": "general",
  "model": "anthropic/claude-haiku-4-5-20251001",
  // Shared system prompt base — always injected into every agent session.
  // Agent-specific persona/loop/rules live in ./agents/<name>.md.
  "instructions": ["./epsilon-system.md"],
  "agent": {
    "build": { "disable": true },
    "plan": { "disable": true },
    "explore": { "disable": true }
  },
  "provider": {
    "anthropic": {
      "npm": "@ai-sdk/anthropic",
      "env": ["ANTHROPIC_API_KEY"],
      "options": {
        "apiKey": "{env:ANTHROPIC_API_KEY}"
      },
      "models": {}
    },
    "anthropic-proxy": {
      "npm": "@ai-sdk/openai-compatible",
      "env": ["ANTHROPIC_PROXY_API_KEY", "ANTHROPIC_PROXY_URL"],
      "options": {
        "baseURL": "{env:ANTHROPIC_PROXY_URL}",
        "apiKey": "{env:ANTHROPIC_PROXY_API_KEY}"
      },
      "models": {
        "claude-opus-4-7": {
          "name": "Claude Opus 4.7 (Proxy)",
          "id": "claude-opus-4-7",
          "family": "anthropic-proxy",
          "limit": { "context": 200000, "output": 32000 }
        },
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6 (Proxy)",
          "id": "claude-sonnet-4-6",
          "family": "anthropic-proxy",
          "limit": { "context": 200000, "output": 64000 }
        },
        "claude-haiku-4-5": {
          "name": "Claude Haiku 4.5 (Proxy)",
          "id": "claude-haiku-4-5-20251001",
          "family": "anthropic-proxy",
          "limit": { "context": 200000, "output": 64000 }
        }
      }
    },
    "epsilon-yolo": {
      "npm": "@ai-sdk/anthropic",
      "env": ["EPSILON_YOLO_API_KEY", "EPSILON_YOLO_URL"],
      "options": {
        "baseURL": "{env:EPSILON_YOLO_URL}",
        "apiKey": "{env:EPSILON_YOLO_API_KEY}"
      },
      "models": {
        "epsilon-yolo/fast": {
          "name": "Fast",
          "id": "epsilon-yolo/fast",
          "family": "epsilon-yolo"
        },
        "epsilon-yolo/think": {
          "name": "Think",
          "id": "epsilon-yolo/think",
          "family": "epsilon-yolo"
        }
      }
    },
    "epsilon": {
      "npm": "@ai-sdk/openai-compatible",
      "env": ["EPSILON_TOKEN", "EPSILON_API_URL"],
      "options": {
        "baseURL": "{env:EPSILON_API_URL}/v1/router",
        "apiKey": "{env:EPSILON_TOKEN}"
      },
      "models": {
        "glm-turbo": {
          "name": "GLM-5 Turbo",
          "id": "z-ai/glm-5-turbo",
          "family": "epsilon",
          "cost": { "input": 1.20, "output": 4.00 },
          "limit": { "context": 202752, "output": 131072 }
        },
        "kimi": {
          "name": "Kimi K2.5",
          "id": "moonshotai/kimi-k2.5",
          "family": "epsilon",
          "cost": { "input": 0.45, "output": 2.20 },
          "limit": { "context": 262144, "output": 65535 }
        },
        "minimax": {
          "name": "MiniMax M2.5",
          "id": "minimax/minimax-m2.5",
          "family": "epsilon",
          "cost": { "input": 0.20, "output": 1.17 },
          "limit": { "context": 196608, "output": 65536 }
        },
        "gpt-4o-mini": {
          "name": "GPT-4o Mini",
          "id": "gpt-4o-mini",
          "family": "epsilon",
          "cost": { "input": 0.15, "output": 0.60 },
          "limit": { "context": 128000, "output": 16384 }
        },
        "gpt-5.4": {
          "name": "GPT-5.4",
          "id": "gpt-5.4",
          "family": "epsilon",
          "cost": { "input": 2.00, "output": 8.00 },
          "limit": { "context": 128000, "output": 16384 }
        },
        "minimax-m27": {
          "name": "MiniMax-M2.7",
          "id": "MiniMax-M2.7",
          "family": "epsilon",
          "cost": { "input": 0.30, "output": 1.20 },
          "limit": { "context": 204800, "output": 131072 }
        },
        "qwen3-6-plus": {
          "name": "Qwen3.6-Plus",
          "id": "qwen3.6-plus",
          "family": "epsilon",
          "cost": { "input": 0.50, "output": 1.50 },
          "limit": { "context": 131072, "output": 32768 }
        },
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6",
          "id": "claude-sonnet-4-6",
          "family": "epsilon",
          "limit": { "context": 200000, "output": 64000 }
        },
        "claude-opus-4-7": {
          "name": "Claude Opus 4.7",
          "id": "claude-opus-4-7",
          "family": "epsilon",
          "limit": { "context": 200000, "output": 32000 }
        },
        "claude-haiku-4-5-20251001": {
          "name": "Claude Haiku 4.5",
          "id": "claude-haiku-4-5-20251001",
          "family": "epsilon",
          "limit": { "context": 200000, "output": 64000 }
        },
        "gemini-3-1-pro-preview": {
          "name": "Gemini 3.1 Pro Preview",
          "id": "gemini-3.1-pro-preview",
          "family": "epsilon",
          "limit": { "context": 1000000, "output": 8192 }
        },
        "gemini-3-1-flash-lite-preview": {
          "name": "Gemini 3.1 Flash Lite Preview",
          "id": "gemini-3.1-flash-lite-preview",
          "family": "epsilon",
          "limit": { "context": 1000000, "output": 8192 }
        }
      }
    }
  },
  "plugin": [
    "./plugin/epsilon-system/epsilon-system.ts",
    "./plugin/opencode-caveman-plugin/opencode-caveman-plugin.ts"
  ],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": true
    },
    "vibe-trading": {
      "type": "remote",
      "url": "{env:EPSILON_API_URL}/v1/router/vibe-trading-mcp/sse",
      "headers": {
        "Authorization": "Bearer {env:EPSILON_TOKEN}"
      },
      "enabled": true
    }
  }
}
