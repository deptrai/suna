#!/usr/bin/with-contenv bash
# Epsilon Master — reverse proxy on port 8000, proxying to OpenCode at localhost:4096

echo "[epsilon-master] Starting on port 8000, proxying to OpenCode at localhost:4096"

exec s6-setuidgid abc \
  env HOME=/workspace \
      EPSILON_MASTER_PORT=8000 \
      OPENCODE_HOST=localhost \
      OPENCODE_PORT=4096 \
      PATH="/opt/bun/bin:/usr/local/bin:/usr/bin:/bin" \
  /opt/bun/bin/bun run /ephemeral/epsilon-master/src/index.ts
