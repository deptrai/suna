{
  "manifest_version": 3,
  "name": "Suna Coin Analysis",
  "version": "1.0.0",
  "description": "Browser extension để analyze crypto coins từ bất kỳ website nào. Click vào coin name để tạo agent chat mới với Suna AI.",
  "permissions": [
    "storage",
    "activeTab",
    "sidePanel"
  ],
  "host_permissions": [
    "https://*.supabase.co/*",
    "https://*.supabase.in/*",
    "https://api.suna.so/*",
    "https://*.suna.so/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.coingecko.com/*",
        "*://*.binance.com/*",
        "*://*.coinmarketcap.com/*",
        "*://*.cryptocompare.com/*",
        "*://*.crypto.com/*",
        "*://*.kraken.com/*",
        "*://*.coinbase.com/*",
        "*://*.gemini.com/*",
        "*://*.bitfinex.com/*",
        "*://*.okx.com/*",
        "*://*.bybit.com/*"
      ],
      "js": [
        "content-script.js"
      ],
      "css": [
        "content-script.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Suna Coin Analysis",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*.png"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}


