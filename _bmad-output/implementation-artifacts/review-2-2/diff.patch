  +import { Worker, Job, Queue } from 'bullmq';
  +import { redisConnection } from '../connection';
  +import { db } from '../../../shared/db';
  +import { discoverFeeds } from '@epsilon/db';
  +import { config } from '../../../config';
  +import { createOpenAI } from '@ai-sdk/openai';
  +import { generateObject } from 'ai';
  +import { z } from 'zod';
  +
  +export const QUEUE_NAME = 'discover-feed-summarization';
  +
  +export const discoverFeedQueue = new Queue(QUEUE_NAME, { connection: redisConnection });
  +
  +// Mock data fetcher for multi-source data
  +async function fetchRawNews() {
  +  // In a real app, this would fetch from Twitter, RSS, Nansen, Dune, etc.
  +  return [
  +    { source: 'Twitter', content: 'Vitalik says Ethereum fees might go down soon.' },
  +    { source: 'CoinDesk', content: 'New zero-day exploit found in popular smart contract protocol.' },
  +    { source: 'Nansen', content: 'Whale 0x123...abc moved 5000 ETH to Binance.' },
  +  ];
  +}
  +
  +const openrouter = createOpenAI({
  +  name: 'openrouter',
  +  baseURL: config.OPENROUTER_API_URL || 'https://openrouter.ai/api/v1',
  +  apiKey: config.OPENROUTER_API_KEY || 'dummy_key',
  +});
  +
  +export const discoverFeedWorker = new Worker(
  +  QUEUE_NAME,
  +  async (job: Job) => {
  +    console.log(`[DiscoverFeedWorker] Starting job ${job.id}`);
  +    
  +    // 1. Fetch multi-source data
  +    const rawData = await fetchRawNews();
  +    const dataString = JSON.stringify(rawData);
  +
  +    // 2. Summarize and analyze via AI
  +    // Ensure strict anonymization by instructing the prompt
  +    const { object } = await generateObject({
  +      model: openrouter('anthropic/claude-3-haiku'),
  +      schema: z.object({
  +        items: z.array(z.object({
  +          title: z.string(),
  +          summary: z.string(),
  +          isAnomaly: z.boolean(),
  +          warningLevel: z.enum(['none', 'low', 'medium', 'high', 'critical']),
  +          sources: z.array(z.object({ name: z.string(), url: z.string().optional() }))
  +        }))
  +      }),
  +      prompt: `You are a crypto intelligence analyst. Summarize the following raw data streams into insightful feed items.
  +        CRITICAL: Ensure strict anonymization. Do not include any PII or user-specific data.
  +        If an event indicates a hack, exploit, or massive dump, mark it as an anomaly with an appropriate warning level.
  +        Data: ${dataString}`,
  +    });
  +
  +    console.log(`[DiscoverFeedWorker] Generated ${object.items.length} items`);
  +
  +    // 3. Insert into DB
  +    for (const item of object.items) {
  +      await db.insert(discoverFeeds).values({
  +        title: item.title,
  +        summary: item.summary,
  +        isAnomaly: item.isAnomaly,
  +        warningLevel: item.warningLevel,
  +        sources: item.sources as any,
  +      });
  +    }
  +
  +    console.log(`[DiscoverFeedWorker] Job ${job.id} completed successfully`);
  +  },
  +  { connection: redisConnection }
  +);
  +
  +export async function setupDiscoverFeedJobs() {
  +  console.log('[DiscoverFeedWorker] Setting up repeatable jobs');
  +  await discoverFeedQueue.add(
  +    'summarize',
  +    {},
  +    {
  +      repeat: {
  +        pattern: '0 * * * *', // Run every hour
  +      },
  +    }
  +  );
  +}
  +
  +export function startDiscoverFeedWorker() {
  +  console.log('[DiscoverFeedWorker] Worker initialized');
  +  return discoverFeedWorker;
  +}
