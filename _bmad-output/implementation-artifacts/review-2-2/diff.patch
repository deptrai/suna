  +import { db } from '@/lib/db';
  +import { Badge } from '@/components/ui/badge'; // Assuming a standard shadcn/ui badge or similar exists
  +import { formatDistanceToNow } from 'date-fns';
  +
  +export const metadata = {
  +  title: 'Discover Feed - Chainlens',
  +};
  +
  +type DiscoverFeedItem = {
  +  id: string;
  +  title: string;
  +  summary: string;
  +  timestamp: Date;
  +  isAnomaly: boolean;
  +  warningLevel: 'none' | 'low' | 'medium' | 'high' | 'critical';
  +  sources: { name: string; url?: string }[] | null;
  +};
  +
  +// Next.js Server Component
  +export default async function DiscoverPage() {
  +  // Fetch latest 50 items
  +  const items = await db.query.discoverFeeds.findMany({
  +    orderBy: (fields, { desc }) => [desc(fields.timestamp)],
  +    limit: 50,
  +  });
  +
  +  const isWithinLast24Hours = (date: Date) => {
  +    const twentyFourHoursAgo = new Date(Date.now() - 24 * 60 * 60 * 1000);
  +    return date > twentyFourHoursAgo;
  +  };
  +
  +  return (
  +    <div className="container max-w-4xl py-8 space-y-8">
  +      <div className="space-y-2">
  +        <h1 className="text-3xl font-bold tracking-tight">Discover</h1>
  +        <p className="text-muted-foreground">
  +          AI-generated news and alpha insights synthesized from multiple sources.
  +        </p>
  +      </div>
  +
  +      <div className="space-y-6">
  +        {items.length === 0 ? (
  +          <div className="text-center py-12 text-muted-foreground">
  +            No discover feeds available yet. Check back soon!
  +          </div>
  +        ) : (
  +          items.map((item: DiscoverFeedItem) => {
  +            const showEarlyWarning = item.isAnomaly && isWithinLast24Hours(item.timestamp);
  +            
  +            return (
  +              <div key={item.id} className="border rounded-lg p-6 space-y-4 bg-card">
  +                <div className="flex items-start justify-between gap-4">
  +                  <div className="space-y-1">
  +                    <h2 className="text-xl font-semibold">{item.title}</h2>
  +                    <div className="text-sm text-muted-foreground">
  +                      {formatDistanceToNow(item.timestamp, { addSuffix: true })}
  +                    </div>
  +                  </div>
  +                  {showEarlyWarning && (
  +                    <Badge variant="destructive" className="shrink-0">
  +                      Early Warning ({item.warningLevel})
  +                    </Badge>
  +                  )}
  +                </div>
  +                
  +                <p className="text-sm leading-relaxed">{item.summary}</p>
  +                
  +                {item.sources && item.sources.length > 0 && (
  +                  <div className="pt-4 border-t flex flex-wrap gap-2 items-center text-xs text-muted-foreground">
  +                    <span className="font-medium">Sources:</span>
  +                    {item.sources.map((src: any, idx: number) => (
  +                      <span key={idx}>
  +                        {src.url ? (
  +                          <a href={src.url} target="_blank" rel="noreferrer" className="hover:underline text-primary">
  +                            {src.name}
  +                          </a>
  +                        ) : (
  +                          <span>{src.name}</span>
  +                        )}
  +                        {idx < (item.sources?.length || 0) - 1 ? ', ' : ''}
  +                      </span>
  +                    ))}
  +                  </div>
  +                )}
  +              </div>
  +            );
  +          })
  +        )}
  +      </div>
  +    </div>
  +  );
  +}
