new file mode 100644
index 000000000..a202c4f19
--- /dev/null
+++ b/apps/api/src/queue/bullmq/crypto-scheduler.ts
@@ -0,0 +1,89 @@
+import { Queue } from 'bullmq';
+import { redisConnection } from './connection';
+import { CRYPTO_SYNC_QUEUE } from './crypto-worker';
+import { DISCOVER_SYNC_QUEUE } from './discover-worker';
+import { ONCHAIN_SYNC_QUEUE } from './onchain-worker';
+
+export const cryptoSyncQueue = new Queue(CRYPTO_SYNC_QUEUE, {
+  connection: redisConnection,
+});
+
+export const discoverSyncQueue = new Queue(DISCOVER_SYNC_QUEUE, {
+  connection: redisConnection,
+});
+
+export const onchainSyncQueue = new Queue(ONCHAIN_SYNC_QUEUE, {
+  connection: redisConnection,
+});
+
+export async function scheduleCryptoSync() {
+  // Clean up any old configurations
+  const jobs = await cryptoSyncQueue.getRepeatableJobs();
+  for (const job of jobs) {
+    if (job.name === 'sync-crypto-data') {
+      await cryptoSyncQueue.removeRepeatableByKey(job.key);
+    }
+  }
+
+  // Schedule the job to run every 15 minutes
+  await cryptoSyncQueue.add(
+    'sync-crypto-data',
+    {},
+    {
+      repeat: {
+        pattern: '*/15 * * * *', // Cron pattern for every 15 minutes
+      },
+    }
+  );
+
+  console.log('Scheduled crypto data sync job (every 15 minutes).');
+}
+
+export async function scheduleDiscoverSync() {
+  const jobs = await discoverSyncQueue.getRepeatableJobs();
+  for (const job of jobs) {
+    if (job.name === 'sync-discover-feed') {
+      await discoverSyncQueue.removeRepeatableByKey(job.key);
+    }
+  }
+
+  // Schedule to run every hour
+  await discoverSyncQueue.add(
+    'sync-discover-feed',
+    {},
+    {
+      repeat: {
+        pattern: '0 * * * *', // Cron pattern for every hour
+      },
+    }
+  );
+
+  console.log('Scheduled discover feed sync job (every 1 hour).');
+}
+
+export async function scheduleOnchainSync() {
+  const jobs = await onchainSyncQueue.getRepeatableJobs();
+  for (const job of jobs) {
+    if (job.name === 'sync-onchain-index') {
+      await onchainSyncQueue.removeRepeatableByKey(job.key);
+    }
+  }
+
+  // Schedule to run every 6 hours, with exponential backoff on failure (max 3 retries for 429)
+  await onchainSyncQueue.add(
+    'sync-onchain-index',
+    {},
+    {
+      repeat: {
+        pattern: '0 */6 * * *', // Cron pattern for every 6 hours
+      },
+      attempts: 3,
+      backoff: {
+        type: 'exponential',
+        delay: 5000, // wait 5s, 25s, etc.
+      }
+    }
+  );
+
+  console.log('Scheduled on-chain index sync job (every 6 hours).');
+}
diff --git a/apps/api/src/queue/bullmq/crypto-worker.ts b/apps/api/src/queue/bullmq/crypto-worker.ts
new file mode 100644
index 000000000..cb54f9085
--- /dev/null
+++ b/apps/api/src/queue/bullmq/crypto-worker.ts
@@ -0,0 +1,125 @@
+import { Worker, Job } from 'bullmq';
+import { redisConnection } from './connection';
+import { db } from '../../shared/db';
+import { cryptoProjects, cryptoTvl, cryptoApy } from '@epsilon/db/schema';
+import { sql } from 'drizzle-orm';
+
+export const CRYPTO_SYNC_QUEUE = 'crypto-sync-queue';
+
+export async function processCryptoSync(job: Job) {
+  try {
+    console.log(`Starting crypto sync job ${job.id}...`);
+
+    // 1. Fetch TVL data
+    console.log('Fetching DeFiLlama protocols...');
+    const tvlResponse = await fetch('https://api.llama.fi/protocols');
+    if (!tvlResponse.ok) {
+      throw new Error(`Failed to fetch protocols: ${tvlResponse.statusText}`);
+    }
+    const protocols: any[] = await tvlResponse.json();
+
+    // Limit to top 200 by TVL
+    const topProtocols = protocols.sort((a, b) => (b.tvl || 0) - (a.tvl || 0)).slice(0, 200);
+    console.log(`Processing ${topProtocols.length} protocols...`);
+
+    const now = new Date();
+    
+    const projectUpserts = topProtocols.map(p => ({
+      slug: p.slug,
+      name: p.name,
+      symbol: p.symbol || null,
+      description: p.description || null,
+      url: p.url || null,
+      category: p.category || null,
+      chain: p.chain || null,
+      updatedAt: now,
+    }));
+
+    // Upsert Projects in chunks to avoid large query limits
+    const chunkSize = 100;
+    for (let i = 0; i < projectUpserts.length; i += chunkSize) {
+      await db.insert(cryptoProjects)
+        .values(projectUpserts.slice(i, i + chunkSize))
+        .onConflictDoUpdate({
+          target: cryptoProjects.slug,
+          set: {
+            name: sql`EXCLUDED.name`,
+            symbol: sql`EXCLUDED.symbol`,
+            description: sql`EXCLUDED.description`,
+            url: sql`EXCLUDED.url`,
+            category: sql`EXCLUDED.category`,
+            chain: sql`EXCLUDED.chain`,
+            updatedAt: now,
+          }
+        });
+    }
+
+    // Retrieve the DB projects to get their internal UUIDs
+    const dbProjects = await db.query.cryptoProjects.findMany({
+      where: (p, { inArray }) => inArray(p.slug, topProtocols.map(x => x.slug))
+    });
+
+    const projectMap = new Map(dbProjects.map(p => [p.slug, p.id]));
+
+    // Insert TVL
+    const tvlInserts = topProtocols.filter(p => projectMap.has(p.slug)).map(p => ({
+      projectId: projectMap.get(p.slug)!,
+      tvl: p.tvl ? String(p.tvl) : '0',
+      timestamp: now,
+    }));
+
+    if (tvlInserts.length > 0) {
+      for (let i = 0; i < tvlInserts.length; i += chunkSize) {
+        await db.insert(cryptoTvl)
+          .values(tvlInserts.slice(i, i + chunkSize))
+          .onConflictDoNothing(); // Prevent duplicates for the same project & timestamp
+      }
+    }
+
+    // 2. Fetch APY data
+    console.log('Fetching DeFiLlama pools...');
+    const apyResponse = await fetch('https://yields.llama.fi/pools');
+    if (!apyResponse.ok) {
+      throw new Error(`Failed to fetch pools: ${apyResponse.statusText}`);
+    }
+    const poolsData: any = await apyResponse.json();
+    const pools: any[] = poolsData.data || [];
+
+    // Filter pools for the projects we track
+    const projectSlugSet = new Set(topProtocols.map(p => p.slug));
+    const relevantPools = pools.filter(p => projectSlugSet.has(p.project));
+
+    const apyInserts = relevantPools.filter(p => projectMap.has(p.project)).map(p => ({
+      projectId: projectMap.get(p.project)!,
+      poolId: p.pool,
+      symbol: p.symbol,
+      chain: p.chain,
+      apy: p.apy ? String(p.apy) : '0',
+      tvlUsd: p.tvlUsd ? String(p.tvlUsd) : '0',
+      timestamp: now,
+    }));
+
+    if (apyInserts.length > 0) {
+      // Chunk APY inserts
+      for (let i = 0; i < apyInserts.length; i += chunkSize) {
+        await db.insert(cryptoApy)
+          .values(apyInserts.slice(i, i + chunkSize))
+          .onConflictDoNothing();
+      }
+    }
+
+    console.log(`Crypto sync job ${job.id} completed successfully.`);
+  } catch (error) {
+    console.error(`Error in crypto sync job ${job.id}:`, error);
+    throw error;
+  }
+}
+
+export const cryptoWorker = new Worker(CRYPTO_SYNC_QUEUE, processCryptoSync, {
+  connection: redisConnection,
+  concurrency: 1, // Start with 1, scale out as needed for auto-scaling
+});
+
+cryptoWorker.on('failed', (job, err) => {
+  console.error(`Job ${job?.id} failed with error: ${err.message}`);
+});
