@@ -0,0 +1,100 @@
+'use client';
+
+import React from 'react';
+import { useDiscoverFeeds } from '@/hooks/epsilon/use-discover-feeds';
+import { Card, CardHeader, CardTitle, CardContent, CardFooter } from '@/components/ui/card';
+import { Badge } from '@/components/ui/badge';
+import { formatDistanceToNow } from 'date-fns';
+import { AlertTriangle, Clock, ExternalLink } from 'lucide-react';
+
+export function DiscoverContent() {
+  const { data: feeds, isLoading, error } = useDiscoverFeeds();
+
+  if (isLoading) {
+    return (
+      <div className="p-8 max-w-4xl mx-auto space-y-4">
+        <h1 className="text-3xl font-bold mb-6">Discover (AI News & Insights)</h1>
+        <div className="animate-pulse space-y-4">
+          {[1, 2, 3].map(i => (
+            <div key={i} className="h-32 bg-accent/50 rounded-xl" />
+          ))}
+        </div>
+      </div>
+    );
+  }
+
+  if (error) {
+    return (
+      <div className="p-8 max-w-4xl mx-auto">
+        <div className="bg-destructive/10 text-destructive p-4 rounded-xl">
+          Failed to load discover feeds. Please try again later.
+        </div>
+      </div>
+    );
+  }
+
+  return (
+    <div className="p-4 md:p-8 max-w-4xl mx-auto h-full space-y-6">
+      <div className="flex items-center justify-between mb-6">
+        <h1 className="text-3xl font-bold tracking-tight">Discover</h1>
+        <Badge variant="outline" className="text-muted-foreground">
+          AI Summarized
+        </Badge>
+      </div>
+      
+      {(!feeds || feeds.length === 0) ? (
+        <div className="text-center p-12 bg-accent/20 rounded-xl border border-border">
+          <p className="text-muted-foreground">No insights available right now.</p>
+        </div>
+      ) : (
+        <div className="grid gap-4">
+          {feeds.map((feed) => (
+            <Card key={feed.id} className={feed.isAnomaly ? "border-destructive/50 shadow-sm" : ""}>
+              <CardHeader className="pb-3">
+                <div className="flex justify-between items-start">
+                  <CardTitle className="text-xl leading-tight">
+                    {feed.title}
+                  </CardTitle>
+                  {feed.isAnomaly && (
+                    <Badge variant="destructive" className="ml-2 shrink-0 flex items-center gap-1">
+                      <AlertTriangle className="h-3 w-3" />
+                      {feed.warningLevel || 'Anomaly'}
+                    </Badge>
+                  )}
+                </div>
+              </CardHeader>
+              <CardContent className="pb-3">
+                <p className="text-muted-foreground">{feed.summary}</p>
+              </CardContent>
+              <CardFooter className="flex flex-wrap gap-4 text-xs text-muted-foreground border-t bg-accent/10 pt-3">
+                <div className="flex items-center gap-1">
+                  <Clock className="h-3 w-3" />
+                  <span>{formatDistanceToNow(new Date(feed.timestamp), { addSuffix: true })}</span>
+                </div>
+                {feed.sources && feed.sources.length > 0 && (
+                  <div className="flex items-center gap-1">
+                    <ExternalLink className="h-3 w-3" />
+                    <span className="flex gap-2">
+                      {feed.sources.map((src, i) => {
+                        try {
+                          const domain = new URL(src).hostname.replace('www.', '');
+                          return (
+                            <a key={i} href={src} target="_blank" rel="noreferrer" className="hover:text-primary transition-colors underline-offset-2 hover:underline">
+                              {domain}
+                            </a>
+                          );
+                        } catch {
+                          return <span key={i}>Source {i+1}</span>;
+                        }
+                      })}
+                    </span>
+                  </div>
+                )}
+              </CardFooter>
+            </Card>
+          ))}
+        </div>
+      )}
+    </div>
+  );
+}
