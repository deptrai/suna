@@ -0,0 +1,36 @@
+import { useQuery } from '@tanstack/react-query';
+import { useServerStore } from '@/stores/server-store';
+import { authenticatedFetch } from '@/lib/auth-token';
+import { useAuth } from '@/components/AuthProvider';
+
+export interface DiscoverFeed {
+  id: string;
+  title: string;
+  summary: string;
+  timestamp: string;
+  isAnomaly: boolean;
+  warningLevel: string | null;
+  sources: string[];
+  createdAt: string;
+}
+
+export function useDiscoverFeeds() {
+  const { user, isLoading: isAuthLoading } = useAuth();
+  const serverUrl = useServerStore((s) => s.getActiveServerUrl());
+  
+  return useQuery<DiscoverFeed[]>({
+    queryKey: ['discover', 'feeds', user?.id ?? 'anonymous', serverUrl],
+    queryFn: async () => {
+      // serverUrl is typically http://localhost:8000/v1/router
+      const url = `${serverUrl.replace(/\/+$/, '')}/discover`;
+      const res = await authenticatedFetch(url);
+      if (!res.ok) {
+        throw new Error('Failed to fetch discover feeds');
+      }
+      const data = await res.json();
+      return data.data || [];
+    },
+    enabled: !isAuthLoading && !!user && !!serverUrl,
+    refetchInterval: 60000, // Refresh every minute
+  });
+}
