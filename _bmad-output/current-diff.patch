+#!/usr/bin/expect
+set timeout 10
+spawn bun run db:generate --name add_discover_feeds
+expect {
+    -re ".*\\?.*" {
+        send "\r"
+        exp_continue
+    }
+    eof
+}
diff --git a/packages/db/src/schema/epsilon.ts b/packages/db/src/schema/epsilon.ts
index deab6beca..a1df51526 100644
--- a/packages/db/src/schema/epsilon.ts
+++ b/packages/db/src/schema/epsilon.ts
@@ -994,3 +994,121 @@ export const accessRequests = epsilonSchema.table(
   ],
 );
 
+// ─── Discover Feeds ──────────────────────────────────────────────────────────
+
+export const discoverFeeds = epsilonSchema.table(
+  'discover_feeds',
+  {
+    id: uuid('id').defaultRandom().primaryKey(),
+    title: varchar('title', { length: 255 }).notNull(),
+    summary: text('summary').notNull(),
+    timestamp: timestamp('timestamp', { withTimezone: true }).defaultNow().notNull(),
+    isAnomaly: boolean('is_anomaly').default(false).notNull(),
+    warningLevel: varchar('warning_level', { length: 50 }),
+    sources: jsonb('sources').default([]).$type<string[]>(),
+    createdAt: timestamp('created_at', { withTimezone: true }).defaultNow().notNull(),
+  },
+  (table) => [
+    index('idx_discover_feeds_timestamp').on(table.timestamp),
+    index('idx_discover_feeds_is_anomaly').on(table.isAnomaly),
+  ],
+);
+
+// ─── Crypto Data Infrastructure ──────────────────────────────────────────────
+
+export const cryptoProjects = epsilonSchema.table(
+  'crypto_projects',
+  {
+    id: uuid('id').defaultRandom().primaryKey(),
+    slug: varchar('slug', { length: 255 }).notNull().unique(),
+    name: varchar('name', { length: 255 }).notNull(),
+    symbol: varchar('symbol', { length: 100 }),
+    description: text('description'),
+    url: varchar('url', { length: 255 }),
+    category: varchar('category', { length: 100 }),
+    chain: varchar('chain', { length: 100 }),
+    createdAt: timestamp('created_at', { withTimezone: true }).defaultNow().notNull(),
+    updatedAt: timestamp('updated_at', { withTimezone: true }).defaultNow().notNull(),
+  },
+  (table) => [
+    index('idx_crypto_projects_slug').on(table.slug),
+    index('idx_crypto_projects_chain').on(table.chain),
+    index('idx_crypto_projects_category').on(table.category),
+  ],
+);
+
+export const cryptoTvl = epsilonSchema.table(
+  'crypto_tvl',
+  {
+    id: uuid('id').defaultRandom().primaryKey(),
+    projectId: uuid('project_id')
+      .notNull()
+      .references(() => cryptoProjects.id, { onDelete: 'cascade' }),
+    tvl: numeric('tvl', { precision: 20, scale: 4 }).notNull(),
+    timestamp: timestamp('timestamp', { withTimezone: true }).defaultNow().notNull(),
+  },
+  (table) => [
+    index('idx_crypto_tvl_project_id').on(table.projectId),
+    index('idx_crypto_tvl_timestamp').on(table.timestamp),
+    uniqueIndex('idx_crypto_tvl_project_time').on(table.projectId, table.timestamp),
+  ],
+);
+
+export const cryptoApy = epsilonSchema.table(
+  'crypto_apy',
+  {
+    id: uuid('id').defaultRandom().primaryKey(),
+    projectId: uuid('project_id')
+      .notNull()
+      .references(() => cryptoProjects.id, { onDelete: 'cascade' }),
+    poolId: varchar('pool_id', { length: 255 }).notNull(),
+    symbol: varchar('symbol', { length: 100 }),
+    chain: varchar('chain', { length: 100 }),
+    apy: numeric('apy', { precision: 10, scale: 4 }).notNull(),
+    tvlUsd: numeric('tvl_usd', { precision: 20, scale: 4 }),
+    timestamp: timestamp('timestamp', { withTimezone: true }).defaultNow().notNull(),
+  },
+  (table) => [
+    index('idx_crypto_apy_project_id').on(table.projectId),
+    index('idx_crypto_apy_pool_id').on(table.poolId),
+    index('idx_crypto_apy_timestamp').on(table.timestamp),
+    uniqueIndex('idx_crypto_apy_pool_time').on(table.poolId, table.timestamp),
+  ],
+);
+
+export const cryptoProjectsRelations = relations(cryptoProjects, ({ many }) => ({
+  tvlRecords: many(cryptoTvl),
+  apyRecords: many(cryptoApy),
+}));
+
+export const cryptoTvlRelations = relations(cryptoTvl, ({ one }) => ({
+  project: one(cryptoProjects, {
+    fields: [cryptoTvl.projectId],
+    references: [cryptoProjects.id],
+  }),
+}));
+
+export const cryptoApyRelations = relations(cryptoApy, ({ one }) => ({
+  project: one(cryptoProjects, {
+    fields: [cryptoApy.projectId],
+    references: [cryptoProjects.id],
+  }),
+}));
+
+export const cryptoOnchainSignals = epsilonSchema.table(
+  'crypto_onchain_signals',
+  {
+    id: uuid('id').defaultRandom().primaryKey(),
+    projectSlug: varchar('project_slug', { length: 100 }).notNull(), // maps to crypto_projects.slug
+    source: varchar('source', { length: 50 }).notNull(), // 'dune' or 'nansen'
+    signalType: varchar('signal_type', { length: 100 }).notNull(), // e.g. 'smart_money_inflow'
+    value: jsonb('value').notNull(), // flexible schema for signal data
+    timestamp: timestamp('timestamp', { withTimezone: true }).defaultNow().notNull(),
+  },
+  (t) => {
+    return {
+      projectSourceIdx: index('idx_crypto_signals_proj_source').on(t.projectSlug, t.source),
+      timestampIdx: index('idx_crypto_signals_timestamp').on(t.timestamp),
+    };
+  }
+);
