# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  epsilon-api — Environment Configuration                                    ║
# ║                                                                             ║
# ║  Copy this file:  cp .env.example .env                                     ║
# ║  Then fill in values below. The server validates all vars at startup        ║
# ║  and will refuse to start if required vars are missing.                     ║
# ║                                                                             ║
# ║  Legend:                                                                    ║
# ║    [REQUIRED]     Server will NOT start without this                        ║
# ║    [CONDITIONAL]  Required when a specific feature is enabled               ║
# ║    [OPTIONAL]     Sane default / feature degrades gracefully if missing     ║
# ╚══════════════════════════════════════════════════════════════════════════════╝


# ─── Core [OPTIONAL] ────────────────────────────────────────────────────────

PORT=8008
ENV_MODE=local                          # local | cloud


# ─── Database [REQUIRED] ────────────────────────────────────────────────────

DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:64322/postgres


# ─── Supabase [REQUIRED] ────────────────────────────────────────────────────

SUPABASE_URL=http://127.0.0.1:64321
SUPABASE_SERVICE_ROLE_KEY=              # from `supabase status` or Supabase dashboard


# ─── Security [REQUIRED] ────────────────────────────────────────────────────

API_KEY_SECRET=                         # 64-char hex string for HMAC hashing API keys


# ─── Internal Deployment Controls [OPTIONAL] ────────────────────────────────
# Safe defaults for self-hosted — only change for Epsilon Cloud.

# INTERNAL_EPSILON_ENV=dev               # dev | staging | prod
# EPSILON_BILLING_INTERNAL_ENABLED=false # optional override; ENV_MODE=cloud implies billing
# EPSILON_ROUTER_INTERNAL_ENABLED=false


# ─── Sandbox [CONDITIONAL] ──────────────────────────────────────────────────
# First entry is the default provider for new sandboxes.

ALLOWED_SANDBOX_PROVIDERS=local_docker  # daytona, local_docker, justavps (comma-separated)

# Required when ALLOWED_SANDBOX_PROVIDERS includes "local_docker":
DOCKER_HOST=                            # e.g. /Users/you/.docker/run/docker.sock
# SANDBOX_NETWORK=                      # custom Docker network (optional)
# SANDBOX_PORT_BASE=14000               # base port for local Docker sandbox mappings
# SANDBOX_CONTAINER_NAME=epsilon-sandbox # Docker container name (change to run multiple instances)

# Required when ALLOWED_SANDBOX_PROVIDERS includes "daytona":
# DAYTONA_API_KEY=
# DAYTONA_SERVER_URL=
# DAYTONA_TARGET=

# Required when ALLOWED_SANDBOX_PROVIDERS includes "justavps":
# JUSTAVPS_API_URL=
# JUSTAVPS_API_KEY=
# JUSTAVPS_IMAGE_ID=                    # optional pin — if unset, auto-resolves latest epsilon-computer-v* image
# JUSTAVPS_DEFAULT_LOCATION=hel1
# JUSTAVPS_DEFAULT_SERVER_TYPE=pro
# JUSTAVPS_IMAGE_BUILD_LOCATION=nbg1   # optional override for pnpm image / pnpm ship
# JUSTAVPS_IMAGE_BUILD_SERVER_TYPE=starter    # smallest EU machine (2v/4GB/80GB) — sufficient for snapshot builds
# JUSTAVPS_PROXY_DOMAIN=epsilon.cloud
# JUSTAVPS_WEBHOOK_SECRET=
# JUSTAVPS_WEBHOOK_URL=

# EPSILON_URL=                           # base URL for sandbox routing (optional)


# ─── Integrations / Pipedream [CONDITIONAL] ──────────────────────────────────
# Required when INTEGRATION_AUTH_PROVIDER=pipedream (the default).
# Get credentials at: https://pipedream.com/connect

INTEGRATION_AUTH_PROVIDER=pipedream
PIPEDREAM_CLIENT_ID=
PIPEDREAM_CLIENT_SECRET=
PIPEDREAM_PROJECT_ID=
PIPEDREAM_ENVIRONMENT=development       # development | production


# ─── Scheduler / Cron [OPTIONAL] ────────────────────────────────────────────

SCHEDULER_ENABLED=true
CRON_TICK_SECRET=                       # secret for pg_cron tick endpoint
# CRON_API_URL is auto-derived from PORT + DOCKER_HOST. Override only if needed:
# CRON_API_URL=http://host.docker.internal:8008


# ─── LLM Providers [OPTIONAL — cloud routing] ───────────────────────────────
# In cloud mode, the router proxies LLM requests using these Epsilon-owned keys.
# Not needed for local mode — sandboxes use their own keys directly.
# Custom API URLs can be set per provider (defaults to official endpoints).

OPENROUTER_API_KEY=                     # primary LLM route — warns if empty
# OPENROUTER_API_URL=https://openrouter.ai/api/v1
# ANTHROPIC_API_KEY=
# ANTHROPIC_API_URL=https://api.anthropic.com/v1
# OPENAI_API_KEY=
# OPENAI_API_URL=https://api.openai.com/v1
# XAI_API_KEY=
# XAI_API_URL=https://api.x.ai/v1
# GEMINI_API_KEY=
# GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta
# GROQ_API_KEY=
# GROQ_API_URL=https://api.groq.com/openai/v1
# AWS_BEARER_TOKEN_BEDROCK=


# ─── Search & Proxy Providers [OPTIONAL] ────────────────────────────────────
# Features degrade gracefully if keys are missing.
# Custom API URLs can be set per provider (defaults to official endpoints).

# TAVILY_API_KEY=
# TAVILY_API_URL=https://api.tavily.com
# SERPER_API_KEY=
# SERPER_API_URL=https://google.serper.dev
# FIRECRAWL_API_KEY=
# FIRECRAWL_API_URL=https://api.firecrawl.dev
# REPLICATE_API_TOKEN=
# REPLICATE_API_URL=https://api.replicate.com
# CONTEXT7_API_KEY=
# CONTEXT7_API_URL=https://context7.com
# FREESTYLE_API_KEY=
# FREESTYLE_API_URL=https://api.freestyle.sh


# ─── Billing [CONDITIONAL — required when ENV_MODE=cloud or EPSILON_BILLING_INTERNAL_ENABLED=true] ─

# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# REVENUECAT_API_KEY=
# REVENUECAT_WEBHOOK_SECRET=


# ─── Channels [OPTIONAL] ────────────────────────────────────────────────────

# CHANNELS_ENABLED=true
# CHANNELS_PUBLIC_URL=
# CHANNELS_CREDENTIAL_KEY=              # 64-char hex for AES-256-GCM credential encryption


# ─── Session Pruning [OPTIONAL] ─────────────────────────────────────────────
# LLM context window management. All have sane defaults.

# SESSION_PRUNING_ENABLED=true
# SESSION_PRUNING_TTL_MS=300000         # idle time before pruning (default 5 min)
# SESSION_PRUNING_KEEP_LAST=3           # trailing turns protected from pruning
# SESSION_PRUNING_SOFT_RATIO=0.3        # context fill ratio triggering soft-trim
# SESSION_PRUNING_HARD_RATIO=0.5        # context fill ratio triggering hard-clear
# SESSION_PRUNING_MIN_CHARS=50000       # min prunable chars before hard-clear
# SESSION_PRUNING_SOFT_MAX=4000         # tool result size threshold for soft-trim
# SESSION_PRUNING_SOFT_HEAD=1500        # chars kept from start during soft-trim
# SESSION_PRUNING_SOFT_TAIL=1500        # chars kept from end during soft-trim
# SESSION_PRUNING_HARD_ENABLED=true
# SESSION_PRUNING_HARD_PLACEHOLDER=[Old tool result content cleared]


# ─── Frontend [OPTIONAL] ────────────────────────────────────────────────────

# FRONTEND_URL=http://localhost:3000


# ─── Tunnel [OPTIONAL] ──────────────────────────────────────────────────────
# Reverse-tunnel to user's local machine. All have sane defaults.

TUNNEL_SIGNING_SECRET=              # Required — HMAC secret for tunnel signing key derivation
# TUNNEL_ENABLED=true
# TUNNEL_HEARTBEAT_INTERVAL_MS=30000
# TUNNEL_HEARTBEAT_MAX_MISSED=3
# TUNNEL_RPC_TIMEOUT_MS=30000
# TUNNEL_MAX_FILE_SIZE=10485760         # 10MB
# TUNNEL_PERMISSION_REQUEST_TTL_MS=300000
# TUNNEL_RATE_LIMIT_RPC=100
# TUNNEL_RATE_LIMIT_PERM_REQUEST=20
# TUNNEL_RATE_LIMIT_WS_CONNECT=5
# TUNNEL_RATE_LIMIT_PERM_GRANT=30
# TUNNEL_MAX_WS_MESSAGE_SIZE=5242880    # 5MB


# ─── Slack [OPTIONAL] ───────────────────────────────────────────────────────

# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=
# SLACK_SIGNING_SECRET=


# ─── Email Notifications / Mailtrap [OPTIONAL] ──────────────────────────────
# Sends a "workspace ready" email when provisioning completes.
# Get your token at: https://mailtrap.io/sending/domains

# MAILTRAP_API_TOKEN=
# MAILTRAP_FROM_EMAIL=noreply@epsilon.com
# MAILTRAP_FROM_NAME=Epsilon


# ─── Version / GitHub [OPTIONAL] ────────────────────────────────────────────

# SANDBOX_VERSION=                      # dev override: force a specific sandbox version
# GITHUB_TOKEN=                         # authenticated GitHub API for changelog fetching


# ─── Networking [OPTIONAL] ──────────────────────────────────────────────────

# CORS_ALLOWED_ORIGINS=                 # extra CORS origins (comma-separated)


# ─── Better Stack Observability [OPTIONAL] ───────────────────────────────────
# Error tracking + structured logging via Better Stack.
# Features degrade gracefully if not configured.

# BETTERSTACK_API_LOG_TOKEN=            # Logtail source token for structured logs
# BETTERSTACK_API_LOG_HOST=             # Logtail ingesting host (e.g. s1234.us-east-9.betterstackdata.com)
# BETTERSTACK_API_SENTRY_DSN=           # Sentry-compatible DSN for error tracking


# ─── Internal / Advanced [OPTIONAL] ─────────────────────────────────────────

# EPSILON_MASTER_URL=                    # sandbox master URL override
# OPENCODE_URL=                         # OpenCode service URL override
# EPSILON_DATA_DIR=                      # data directory override


# ─── Internal Service Key [AUTO-GENERATED] ──────────────────────────────────
# Auto-generated on first startup if missing. Do not remove once set.

# INTERNAL_SERVICE_KEY=


# ─── JustAVPS [OPTIONAL] ────────────────────────────────────────────────────
# JUSTAVPS_API_URL=https://justavps.com/api/v1
# JUSTAVPS_API_KEY=
# JUSTAVPS_IMAGE_ID=
# JUSTAVPS_WEBHOOK_SECRET=
# JUSTAVPS_DEFAULT_LOCATION=nbg1
# JUSTAVPS_DEFAULT_SERVER_TYPE=pro

# ─── On-Chain Data Providers [OPTIONAL] ─────────────────────────────────────
NANSEN_API_KEY=
DUNE_API_KEY=
DUNE_SMART_MONEY_QUERY_ID=7431659
# ONCHAIN_WORKER_ENABLED=false   # set true to start the Dune/Nansen indexer
# ONCHAIN_RETENTION_DAYS=30      # daily cleanup deletes rows older than this

# ─── Vibe Trading Backtesting Service [OPTIONAL] ────────────────────────────
# Internal backtesting sandbox service. Set a strong random string for API_AUTH_KEY.
# Generate: openssl rand -hex 32
# VIBE_TRADING_API_KEY=                   # shared secret for epsilon-api ↔ vibe-trading auth
# VIBE_TRADING_INTERNAL_URL=http://vibe-trading:8899  # override if service runs elsewhere
# VIBE_TRADING_ALLOWED_IPS=172.28.0.0/16  # CIDR — MUST match `networks.sandbox-network.ipam.config.subnet`
                                          # in scripts/compose/docker-compose.yml. Both default to 172.28.0.0/16.
                                          # Vibe-Trading 403s any container outside this subnet (api_server.py:351-357).


# ─── Token Holders / Transactions Providers (Story 3.4) [OPTIONAL] ──────────
# Moralis Web3 Data API — used by /v1/router/token-holders. Free tier 25k req/day at moralis.io.
# When unset, Top Holders section renders an actionable "MORALIS_API_KEY required" message.
MORALIS_API_KEY=
# Etherscan family — used by /v1/router/token-transactions. Free tier 5cps/100k day.
# When unset, the service falls back to Blockscout (keyless, Etherscan-compatible) for ethereum/base/arbitrum/polygon.
ETHERSCAN_API_KEY=
ARBISCAN_API_KEY=
BASESCAN_API_KEY=
POLYGONSCAN_API_KEY=


# ─── BullMQ / Redis [CONDITIONAL] ───────────────────────────────────────────
# Required when CRYPTO_WORKER_ENABLED=true OR DEFILLAMA_WORKER_ENABLED=true.
# REDIS_URL=redis://localhost:6379


# ─── Crypto Watchlist Worker — Story 2.1 [OPTIONAL] ─────────────────────────
# Hot-tier worker: refresh ~15 protocols in protocol_watchlist table every 5 min.
# CRYPTO_WORKER_ENABLED=false           # set true to start the BullMQ crypto worker
# CRYPTO_SYNC_INTERVAL_MS=300000        # 5 minutes default
# CRYPTO_WORKER_CONCURRENCY=1


# ─── DeFiLlama Full Crawler — Stories 2.4–2.7 [OPTIONAL] ────────────────────
# Full-tier worker: refresh ~7,000 protocols + ~16,000 yield pools + DEX volumes
# + Fees + Stablecoins (+ Hacks/Emissions/Bridges if Pro key set) every 1 hour.
# Pro subscription ($300/mo) unlocks higher rate limits and Pro-only endpoints.
# When unset, worker falls back to Free tier (lower rate limits, no hacks/emissions).
# DEFILLAMA_WORKER_ENABLED=false        # set true to start the BullMQ defillama worker
# DEFILLAMA_SYNC_INTERVAL_MS=3600000    # 1 hour default
# DEFILLAMA_PRO_API_KEY=                # https://defillama.com/pro-api — leave empty for Free tier


# ─── Social Sentiment Worker — Story 2.2.2 [OPTIONAL] ───────────────────────
# Fetches social volume, dominance, sentiment, and price data from Santiment.
# Requires Santiment Max tier ($249/mo) for real-time data.
# Pro tier ($49/mo) has 30-day delayed data — insufficient for alpha signals.
# Rate limit: 80,000 calls/month Max tier. Recommended interval: 30 min.
# SANTIMENT_API_KEY=                    # https://app.santiment.net/account#api-keys
# SOCIAL_SENTIMENT_WORKER_ENABLED=false # set true to start the social sentiment worker
# SOCIAL_SENTIMENT_INTERVAL_MS=1800000  # 30 minutes default (budget-safe for Max tier)
