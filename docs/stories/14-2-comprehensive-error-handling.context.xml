  <story>
    <asA>user</asA>
    <iWant>clear error messages khi things go wrong</iWant>
    <soThat>I understand what happened và how to fix it</soThat>
    <tasks>
      <task id="1" ac="1">
        <title>Reuse frontend error handler</title>
        <subtasks>
          <subtask>Import error handler từ `@/lib/error-handler`</subtask>
          <subtask>Or adapt error handler for extension</subtask>
          <subtask>Use error handler trong API calls</subtask>
          <subtask>Test error handler works</subtask>
        </subtasks>
      </task>
      <task id="2" ac="2">
        <title>Handle network errors</title>
        <subtasks>
          <subtask>Detect network errors (timeout, connection failed)</subtask>
          <subtask>Display user-friendly error message</subtask>
          <subtask>Suggest checking internet connection</subtask>
          <subtask>Provide retry option</subtask>
        </subtasks>
      </task>
      <task id="3" ac="3">
        <title>Handle authentication errors</title>
        <subtasks>
          <subtask>Detect 401/403 errors</subtask>
          <subtask>Prompt user to re-login</subtask>
          <subtask>Redirect to login UI</subtask>
          <subtask>Clear invalid auth state</subtask>
        </subtasks>
      </task>
      <task id="4" ac="4">
        <title>Display API error details</title>
        <subtasks>
          <subtask>Extract error details from API response</subtask>
          <subtask>Display specific error message</subtask>
          <subtask>Show error code if available</subtask>
          <subtask>Format error message clearly</subtask>
        </subtasks>
      </task>
      <task id="5" ac="5">
        <title>Handle content script errors</title>
        <subtasks>
          <subtask>Wrap content script code in try-catch</subtask>
          <subtask>Log errors to console</subtask>
          <subtask>Don't break page functionality</subtask>
          <subtask>Handle errors gracefully</subtask>
        </subtasks>
      </task>
      <task id="6" ac="6">
        <title>Provide error recovery</title>
        <subtasks>
          <subtask>Add retry buttons for recoverable errors</subtask>
          <subtask>Add "Go to Login" for auth errors</subtask>
          <subtask>Add "Refresh" for network errors</subtask>
          <subtask>Provide helpful error messages</subtask>
        </subtasks>
      </task>
    </tasks>
  </story>

